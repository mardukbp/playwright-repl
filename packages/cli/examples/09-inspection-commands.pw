# Test inspection commands: snapshot, highlight, console, network
# App: https://demo.playwright.dev/todomvc/

goto https://demo.playwright.dev/todomvc/
localstorage-clear
reload
fill textbox "What needs to be done?" "Buy groceries"
press Enter

# Snapshot
snapshot

# Highlight
highlight "Buy groceries"

# Console and network
console
network

# Verify visible
verify-visible textbox "What needs to be done?"

# Cleanup
localstorage-clear
