{
  "name": "@playwright-repl/runner",
  "version": "0.26.1",
  "description": "Playwright test runner CLI",
  "type": "module",
  "bin": {
    "pw": "./dist/pw-cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "test:e2e": "node dist/pw-cli.js test",
    "test:benchmark": "echo '--- Standard Playwright ---' && npx playwright test --workers=1 && echo '--- pw ---' && node dist/pw-cli.js test"
  },
  "dependencies": {
    "@playwright-repl/core": "workspace:*"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.57.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^5.0.0"
  }
}
